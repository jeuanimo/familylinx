*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environment
# =============================================================================
venv/
ENV/
env/
.venv/

# =============================================================================
# Environment Variables (SECURITY: Never commit!)
# =============================================================================
.env
.env.local
.env.production
*.env

# =============================================================================
# Django
# =============================================================================
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/

# =============================================================================
