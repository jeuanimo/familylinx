# =============================================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# =============================================================================
# Jupyter Notebook
# =============================================================================
.ipynb_checkpoints

# =============================================================================
