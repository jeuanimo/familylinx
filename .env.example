# FamilyLinx Environment Configuration
# Copy this to .env and customize for your environment
# NEVER commit .env to version control!

# =============================================================================
# DJANGO SETTINGS
# =============================================================================

# SECURITY: Generate a new secret key for production!
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-key-change-in-production

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated, set for production domain)
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE (PostgreSQL for production)
# =============================================================================

# Uncomment and configure for PostgreSQL:
# DB_NAME=familylinx
# DB_USER=familylinx
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# For Gmail SMTP:
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=FamilyLinx <noreply@familylinx.com>

# =============================================================================
# LOGGING
# =============================================================================

DJANGO_LOG_LEVEL=INFO
